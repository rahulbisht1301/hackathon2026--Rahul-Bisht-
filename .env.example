GEMINI_API_KEY=your_gemini_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING_V2=false
LANGSMITH_PROJECT=shopwave-agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shopwave_agent
POSTGRES_USER=shopwave
POSTGRES_PASSWORD=change_me_in_production
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=shopwave_kb
LLM_MODEL=models/gemini-2.5-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
AGENT_CONCURRENCY_LIMIT=5
AGENT_CONFIDENCE_THRESHOLD=0.6
AGENT_MAX_ITERATIONS=15
AGENT_MIN_TOOL_CALLS=3
# true => planner enforces tickets.json expected_action as strict target
# false => planner falls back to category policy planning
PLANNER_STRICT_EXPECTED_ACTION=true
TOOL_FAILURE_RATE=0.15
# Demo run profile (recommended for judge/demo runs):
# TOOL_FAILURE_RATE=0.0
# AGENT_CONFIDENCE_THRESHOLD=0.5
# AGENT_MAX_ITERATIONS=20
TOOL_TIMEOUT_SECONDS=3.0
TOOL_FAILURE_SEED=7
TOOL_MAX_RETRIES=3
TOOL_RETRY_DELAYS=1.0,2.0,4.0
POLICY_REFERENCE_DATE=2024-03-15
KB_TOP_K=3
REFUND_ESTIMATED_DAYS=7
ESCALATION_ASSIGNED_TO=human_support_queue
DATA_DIR=./data
AUDIT_LOG_PATH=./audit_log.json
RUN_REPORT_PATH=./output/run_report.json
LOG_LEVEL=INFO
LOG_FORMAT=json

